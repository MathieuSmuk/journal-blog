# Local PostgreSQL configuration
DB_USER=postgres
DB_HOST=localhost
DB_NAME=journal_blog
DB_PASSWORD=your_database_password
DB_PORT=5432

# Hosted PostgreSQL configuration
# When DATABASE_URL is provided, it takes precedence over the DB_* variables.
DATABASE_URL=

# Authentication
JWT_SECRET=replace_with_a_long_random_secret

# Server
PORT=3000

# Frontend address used for CORS
CLIENT_URL=http://localhost:5173